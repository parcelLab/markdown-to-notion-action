{
  "name": "markdown-to-notion-action",
  "version": "3.0.0",
  "description": "Syncs Markdown files to Notion database items.",
  "license": "MIT",
  "type": "module",
  "main": "src/main.ts",
  "scripts": {
    "start": "tsx src/main.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "hooks:install": "git config core.hooksPath .githooks",
    "precommit": "npm run format && npm run typecheck && npm run lint && npm test && npm run knip",
    "test": "tsx --import ./test/setup.ts --test test/**/*.test.ts"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@notionhq/client": "^5.23.2",
    "@tryfabric/martian": "^1.2.4",
    "js-yaml": "^5.2.1",
    "markdown-it": "^14.3.0",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.4",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^72.0.0",
    "knip": "^6.14.1",
    "nock": "^14.0.16",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.8",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "katex": "0.16.45"
  }
}
